# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Tool reports
.jscpd/
coverage/

# Env files — committed publishable keys still tie the repo to a specific
# account. Sensitive values live in host env (Cloudflare Pages, Supabase
# secrets). `.env.example` documents the shape.
.env
.env.*
!.env.example
!.env.example.*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vercel

# Local audio staging for scripts/upload-music.mjs (never commit raw tracks)
music-drop/

# Standalone admin build output
dist-admin/

# Electron desktop build output (.dmg/.app)
dist-desktop/

# Intermediate macOS iconset (regenerable; the committed icon.icns is what builds use)
build/icon.iconset/

# Playwright test artifacts
test-results/
playwright-report/
qa/.testuser.json
qa/.auth.json
qa/.bizuser.json
qa/.bizauth.json

# Local Claude Code agent state (worktrees, locks) — never commit
.claude/
