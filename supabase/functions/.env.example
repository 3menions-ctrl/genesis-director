# ──────────────────────────────────────────────────────────────────────────
# Small Bridges — edge function secrets.
# Set via `supabase secrets set KEY=value` per environment. Never commit.
# ──────────────────────────────────────────────────────────────────────────

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers — keep both names recognized for now, but prefer REPLICATE_API_TOKEN.
REPLICATE_API_TOKEN=
REPLICATE_WEBHOOK_SECRET=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
LOVABLE_API_KEY=
LOVABLE_SEND_URL=

# Pinned model versions (optional)
LANDING_PREVIEW_MODEL_VERSION=
MOTION_TRANSFER_MODEL_VERSION=

# Payments — Stripe (direct API, no proxy gateway)
# Primary secret key (sk_live_… in prod, sk_test_… in dev). The prefix
# selects live vs test mode. STRIPE_SANDBOX_SECRET_KEY is optional and
# only used when a localhost caller requests the sandbox environment.
STRIPE_SECRET_KEY=
STRIPE_SANDBOX_SECRET_KEY=
# Webhook signing secrets (whsec_…) for payments-webhook signature verify.
PAYMENTS_LIVE_WEBHOOK_SECRET=
PAYMENTS_SANDBOX_WEBHOOK_SECRET=

# Optional alternative payment rails (OSS-first)
LEMONSQUEEZY_WEBHOOK_SECRET=
BTCPAY_WEBHOOK_SECRET=
BTCPAY_HOST=

# Auth / OAuth
OAUTH_STATE_SECRET=

# Push notifications (VAPID, web-push OSS)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:hello@smallbridges.com"

# Operational
PUBLIC_SITE_URL="https://smallbridges.com"
CRON_SHARED_SECRET=
SEED_BYPASS_TOKEN=
WATCHDOG_RESUME_ENABLED="true"

# Admin alerting
ADMIN_DISCORD_WEBHOOK_URL=
ADMIN_SLACK_WEBHOOK_URL=
