<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CAPACITOR_DEBUG</key>
	<string>$(CAPACITOR_DEBUG)</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
        <string>Small Bridges</string>
	<!-- Photo upload uses the WKWebView file picker (avatar, cover, and film
	     photos). Its "Take Photo" / "Photo Library" options access the camera and
	     photo library in-process, so iOS REQUIRES these purpose strings — without
	     them the app hard-crashes the moment a user picks that option, and App
	     Review rejects. The app only READS photos (never saves to the library), so
	     NSPhotoLibraryAddUsageDescription is intentionally not declared. -->
	<key>NSCameraUsageDescription</key>
	<string>Small Bridges uses the camera so you can take a photo for your avatar, cover image, or a film, and to broadcast when you go live.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Small Bridges uses the microphone so your audience can hear you when you go live.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Small Bridges accesses your photos so you can choose a picture for your avatar, cover image, or a film.</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>armv7</string>
	</array>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<!-- Custom-scheme deep links: smallbridges://<path> opens the app and is
	     routed by src/components/native/NativeShell.tsx. Works without an Apple
	     Developer account. Universal Links (https://smallbridges.co/...) require
	     an Associated Domains entitlement + apple-app-site-association file —
	     see IOS_SETUP.md. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>co.smallbridges.app</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>smallbridges</string>
			</array>
		</dict>
	</array>
	<!-- Allow delivery of background/content pushes. Alert pushes also require
	     the Push Notifications capability (aps-environment entitlement), added
	     via Xcode → Signing & Capabilities (needs Apple Developer). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- The app uses only standard HTTPS/exempt encryption. Declaring this
	     skips the export-compliance question on every TestFlight/App Store
	     upload. If you ever add non-exempt crypto, set this to true and file
	     the appropriate compliance docs. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
</dict>
</plist>
