# ──────────────────────────────────────────────────────────────────────────
# Small Bridges — frontend env shape.
# Copy to `.env.local` for dev. Set values in host env for deploy
# (Cloudflare Pages, Vercel, Fly, etc.). Never commit a real `.env*` file.
# ──────────────────────────────────────────────────────────────────────────

# Supabase (public)
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_URL=""
VITE_SUPABASE_PUBLISHABLE_KEY=""

# Payments — provider is abstracted behind src/lib/payments/PaymentsProvider.
# Active provider: Polar.sh (merchant of record — handles global VAT/sales tax).
VITE_PAYMENTS_PROVIDER="polar"           # polar | stripe | lemonsqueezy | paddle | btcpay
VITE_PAYMENTS_CLIENT_TOKEN=""
#
# Polar backend secrets (set via `supabase secrets set …`, NEVER in the client):
#   POLAR_ACCESS_TOKEN     organization access token (polar_oat_…)
#   POLAR_WEBHOOK_SECRET   signing secret from the Polar webhook settings
#   POLAR_SERVER           production | sandbox   (default sandbox)
#   POLAR_PRODUCT_MINI / _STARTER / _GROWTH / _AGENCY   credit-pack product UUIDs
#   POLAR_PRODUCT_<PRICEID>  subscription-plan product UUIDs (or pass a raw UUID)
# Webhook endpoint to register in Polar:
#   https://<project-ref>.supabase.co/functions/v1/polar-webhook

# Optional CDN swap for landing-page demo assets
VITE_LANDING_ASSET_BASE=""

# Diagnostics overlay (dev only)
VITE_DIAGNOSTICS_MODE=""

# Observability — GlitchTip (Sentry-compatible OSS) DSN; PostHog OSS host
VITE_GLITCHTIP_DSN=""
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://eu.posthog.com"   # or your self-hosted URL

# Optional Cloudflare Turnstile site key (replaces hCaptcha/reCAPTCHA)
VITE_TURNSTILE_SITE_KEY=""
